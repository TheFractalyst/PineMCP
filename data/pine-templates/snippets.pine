// ── SNIPPET 18: barstate Guards ══════════════════════════════════════════════
// Source: get_variable("barstate.isconfirmed"), get_variable("barstate.isfirst"),
//         get_variable("barstate.islast")
// barstate.isconfirmed — true on the close of a bar (prevents repainting)
// barstate.isfirst     — true only on bar 0 (init logic)
// barstate.islast      — true on the last/realtime bar (cleanup, final labels)
// Validated: pine-facade ✅

// Init: runs once on bar 0
if barstate.isfirst
    // one-time setup code here
    // e.g. table creation, array initialisation
    runtime.log("Script started on: " + str.tostring(time, "yyyy-MM-dd"))

// Confirmed bar: strategy decisions, alert conditions
if barstate.isconfirmed
    // strategy.entry(...) — safe here, bar is closed, no repainting
    // alertcondition logic is evaluated per bar automatically
    runtime.log("Bar closed at: " + str.tostring(close, "#.####"))

// Last bar: cleanup and final annotations
if barstate.islast
    // strategy.close_all() in strategy scripts
    // delete + redraw persistent labels/lines
    runtime.log("Last bar: " + str.tostring(bar_index))

