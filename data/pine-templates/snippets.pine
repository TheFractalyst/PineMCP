//@version=6
// ══════════════════════════════════════════════════════════════════════════════
// PineScript v6 Validated Snippets
// All snippets sourced from pinescript-v6 MCP server (1,647 entries)
// Each snippet verified against live TradingView docs
// Validated: pine-facade local check ✅
// ══════════════════════════════════════════════════════════════════════════════
//
// USAGE: Copy any snippet block into your script.
//        Every snippet is self-contained and tested.
//        Replace placeholder inputs with input.* variables in production.
//
indicator("Snippets Reference", overlay = false)

// ── SNIPPET 1: EMA / SMA / RMA / WMA ════════════════════════════════════════
// Source: get_function("ta.ema"), get_function("ta.sma"),
//         get_function("ta.rma"), get_function("ta.wma")
// Syntax confirmed from MCP:
//   ta.ema(source, length) → series float    (alpha = 2 / (length + 1))
//   ta.sma(source, length) → series float    (simple average)
//   ta.rma(source, length) → series float    (alpha = 1 / length, used in RSI)
//   ta.wma(source, length) → series float    (linearly weighted)
// Validated: pine-facade ✅

i_ma_src = input.source(close, "MA Source")
i_ma_len = input.int(14, "MA Length", minval = 1)

ema_val = ta.ema(i_ma_src, i_ma_len)
sma_val = ta.sma(i_ma_src, i_ma_len)
rma_val = ta.rma(i_ma_src, i_ma_len)
wma_val = ta.wma(i_ma_src, i_ma_len)

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 2: RSI with Overbought / Oversold Levels ════════════════════════
// Source: get_function("ta.rsi")
// Syntax: ta.rsi(source, length) → series float
// Returns: Relative Strength Index (0–100).  Uses ta.rma() internally.
// Validated: pine-facade ✅

i_rsi_src = input.source(close, "RSI Source")
i_rsi_len = input.int(14, "RSI Length", minval = 1)
i_rsi_ob  = input.int(70, "Overbought", minval = 50, maxval = 100)
i_rsi_os  = input.int(30, "Oversold",   minval = 0,  maxval = 50)

rsi_val = ta.rsi(i_rsi_src, i_rsi_len)

rsi_ob_cross = ta.crossunder(rsi_val, i_rsi_ob)  // price rolling over from OB
rsi_os_cross = ta.crossover(rsi_val,  i_rsi_os)  // price bouncing from OS

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 3: MACD with Signal and Histogram ════════════════════════════════
// Source: get_function("ta.macd")
// Syntax: ta.macd(source, fastlen, slowlen, siglen) → [series float, series float, series float]
// Returns: [macd_line, signal_line, histogram]
// Validated: pine-facade ✅

i_macd_src   = input.source(close, "MACD Source")
i_macd_fast  = input.int(12, "Fast Length",   minval = 1)
i_macd_slow  = input.int(26, "Slow Length",   minval = 1)
i_macd_sig   = input.int(9,  "Signal Length", minval = 1)

[macd_line, macd_signal, macd_hist] = ta.macd(i_macd_src, i_macd_fast, i_macd_slow, i_macd_sig)

macd_bull = ta.crossover(macd_line, macd_signal)   // bullish cross
macd_bear = ta.crossunder(macd_line, macd_signal)  // bearish cross

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 4: Bollinger Bands ═══════════════════════════════════════════════
// Source: get_function("ta.bb")
// Syntax: ta.bb(series, length, mult) → [series float, series float, series float]
// Returns: [basis (SMA), upper band, lower band]
// Validated: pine-facade ✅

i_bb_src  = input.source(close, "BB Source")
i_bb_len  = input.int(20,  "BB Length",     minval = 1)
i_bb_mult = input.float(2.0, "BB Std Dev ×", minval = 0.1, step = 0.1)

[bb_basis, bb_upper, bb_lower] = ta.bb(i_bb_src, i_bb_len, i_bb_mult)

bb_squeeze   = (bb_upper - bb_lower) / bb_basis  // normalized bandwidth
bb_above_upp = close > bb_upper                   // price outside upper
bb_below_low = close < bb_lower                   // price outside lower

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 5: ATR for Stop Loss Distance ════════════════════════════════════
// Source: get_function("ta.atr")
// Syntax: ta.atr(length) → series float
// Uses high / low / close internally (no source arg).
// True range = max(high-low, abs(high-close[1]), abs(low-close[1]))
// Validated: pine-facade ✅

i_atr_len    = input.int(14,  "ATR Length", minval = 1)
i_atr_sl_mul = input.float(1.5, "Stop Loss ATR ×", minval = 0.1, step = 0.1)
i_atr_tp_mul = input.float(3.0, "Take Profit ATR ×", minval = 0.1, step = 0.1)

atr_val      = ta.atr(i_atr_len)
stop_long    = close - atr_val * i_atr_sl_mul
tp_long      = close + atr_val * i_atr_tp_mul
stop_short   = close + atr_val * i_atr_sl_mul
tp_short     = close - atr_val * i_atr_tp_mul

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 6: Volume-Weighted Conditions ════════════════════════════════════
// Source: get_function("ta.vwma"), get_variable("volume")
// Syntax: ta.vwma(source, length) → series float
// Volume spike: current volume > N × average volume
// Validated: pine-facade ✅

i_vwma_len    = input.int(20, "VWMA Length",       minval = 1)
i_vol_mult    = input.float(2.0, "Volume Spike ×", minval = 1.0, step = 0.1)

vwma_val      = ta.vwma(close, i_vwma_len)
avg_vol       = ta.sma(volume, i_vwma_len)
vol_spike     = volume > avg_vol * i_vol_mult
price_above_vwma = close > vwma_val

// Combined: price above VWMA with volume confirmation
vol_bull_signal = price_above_vwma and vol_spike

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 7: Crossover / Crossunder Detection ══════════════════════════════
// Source: get_function("ta.crossover"), get_function("ta.crossunder")
// Syntax:
//   ta.crossover(source1, source2)  → series bool  (source1 crosses above source2)
//   ta.crossunder(source1, source2) → series bool  (source1 crosses below source2)
// Validated: pine-facade ✅

i_cross_fast = input.int(9,  "Cross Fast MA", minval = 1)
i_cross_slow = input.int(21, "Cross Slow MA", minval = 1)

fast_cross_ma = ta.ema(close, i_cross_fast)
slow_cross_ma = ta.ema(close, i_cross_slow)

golden_cross = ta.crossover(fast_cross_ma,  slow_cross_ma)  // bullish
death_cross  = ta.crossunder(fast_cross_ma, slow_cross_ma)  // bearish

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 8: Higher Timeframe Data with request.security() ═════════════════
// Source: get_function("request.security")
// Syntax: request.security(symbol, timeframe, expression, gaps, lookahead, ...) → series <type>
// IMPORTANT: cache result in var — never call inside a loop
// lookahead=barmerge.lookahead_off (default) prevents repainting
// Validated: pine-facade ✅

i_htf = input.timeframe("D", "Higher Timeframe")

// Cache outside any loop or conditional — RULE from CLAUDE.md
htf_close = request.security(syminfo.tickerid, i_htf, close,               gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
htf_high  = request.security(syminfo.tickerid, i_htf, high,                gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
htf_low   = request.security(syminfo.tickerid, i_htf, low,                 gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
htf_ema   = request.security(syminfo.tickerid, i_htf, ta.ema(close, 50),   gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

htf_trend_up = close > htf_ema  // current price above HTF EMA = uptrend

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 9: Drawing a Label at Bar High ═══════════════════════════════════
// Source: get_function("label.new")
// Syntax: label.new(point, text, xloc, yloc, color, style, textcolor, size, ...) → series label
// IMPORTANT: always delete old label — do not create new one every bar
// Uses chart.point.now() for v6-style point creation
// Validated: pine-facade ✅

i_label_cond = input.bool(true, "Show High Label")

var label lbl_high = na
if i_label_cond and barstate.islast
    label.delete(lbl_high)
    lbl_high := label.new(
         point     = chart.point.now(high),
         text      = "H: " + str.tostring(high, "#.####"),
         style     = label.style_label_down,
         color     = color.new(color.blue, 70),
         textcolor = color.white,
         size      = size.small
         )

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 10: Drawing a Horizontal Line at a Price ═════════════════════════
// Source: get_function("line.new")
// Syntax: line.new(first_point, second_point, xloc, extend, color, style, width) → series line
// extend=extend.right draws a ray to the right from the anchor bar
// Validated: pine-facade ✅

i_hline_price = input.float(0.0, "Horizontal Line Price", step = 0.0001)
i_hline_show  = input.bool(false, "Show Horizontal Line")

var line hline_obj = na
if i_hline_show and barstate.islast
    line.delete(hline_obj)
    hline_obj := line.new(
         first_point  = chart.point.now(i_hline_price),
         second_point = chart.point.from_index(bar_index + 1, i_hline_price),
         extend       = extend.right,
         color        = color.new(color.orange, 0),
         style        = line.style_dashed,
         width        = 1
         )

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 11: Drawing a Box Between Two Bars ═══════════════════════════════
// Source: get_function("box.new")
// Syntax: box.new(top_left, bottom_right, border_color, border_width, ..., bgcolor) → series box
// Uses chart.point for v6-style corner coordinates
// Validated: pine-facade ✅

i_box_len  = input.int(10, "Box Lookback Bars", minval = 2)
i_box_show = input.bool(true, "Show Range Box")

var box range_box = na
if i_box_show and barstate.islast
    box.delete(range_box)
    box_high = ta.highest(high, i_box_len)
    box_low  = ta.lowest(low,  i_box_len)
    range_box := box.new(
         top_left     = chart.point.from_index(bar_index - i_box_len + 1, box_high),
         bottom_right = chart.point.now(box_low),
         border_color = color.new(color.purple, 0),
         border_width = 1,
         bgcolor      = color.new(color.purple, 90)
         )

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 12: Table in Corner with Live Values ══════════════════════════════
// Source: get_function("table.new"), get_function("table.cell")
// Syntax: table.new(position, columns, rows, bgcolor, ...) → series table
//         table.cell(table_id, column, row, text, ...) → void
// Create once with var, update cells every bar
// Validated: pine-facade ✅

var table info_tbl = na
if barstate.isfirst
    info_tbl := table.new(
         position     = position.top_right,
         columns      = 2,
         rows         = 4,
         bgcolor      = color.new(color.black, 80),
         frame_color  = color.new(color.gray, 50),
         frame_width  = 1,
         border_color = color.new(color.gray, 70),
         border_width = 1
         )

if not na(info_tbl)
    table.cell(info_tbl, 0, 0, "Symbol", text_color = color.gray,  text_size = size.small)
    table.cell(info_tbl, 1, 0, syminfo.tickerid, text_color = color.white, text_size = size.small)
    table.cell(info_tbl, 0, 1, "Close",  text_color = color.gray,  text_size = size.small)
    table.cell(info_tbl, 1, 1, str.tostring(close, "#.####"), text_color = color.white, text_size = size.small)
    table.cell(info_tbl, 0, 2, "RSI",    text_color = color.gray,  text_size = size.small)
    rsi_tbl  = ta.rsi(close, 14)
    rsi_tcolor = rsi_tbl >= 70 ? color.red : rsi_tbl <= 30 ? color.green : color.white
    table.cell(info_tbl, 1, 2, str.tostring(rsi_tbl, "#.##"), text_color = rsi_tcolor, text_size = size.small)
    table.cell(info_tbl, 0, 3, "ATR",    text_color = color.gray,  text_size = size.small)
    table.cell(info_tbl, 1, 3, str.tostring(ta.atr(14), "#.####"), text_color = color.white, text_size = size.small)

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 13: Alert Condition with Dynamic Message ═════════════════════════
// Source: get_function("alertcondition"), get_function("alert")
// alertcondition() — registers a named condition, fires when user enables it
// alert()          — fires programmatically within script execution
// RULE: never use static strings — always embed str.tostring() for context
// Validated: pine-facade ✅

i_alert_src = input.source(close, "Alert Source")
i_alert_ma  = input.int(20, "Alert MA Length", minval = 1)

alert_ma = ta.sma(i_alert_src, i_alert_ma)

// Named alert condition (appears in TradingView alert dialog)
alertcondition(
     ta.crossover(i_alert_src, alert_ma),
     title   = "Price Crossed Above MA",
     message = "{{ticker}} crossed above " + str.tostring(i_alert_ma) + "-bar SMA at " + str.tostring(close, "#.####")
     )

alertcondition(
     ta.crossunder(i_alert_src, alert_ma),
     title   = "Price Crossed Below MA",
     message = "{{ticker}} crossed below " + str.tostring(i_alert_ma) + "-bar SMA at " + str.tostring(close, "#.####")
     )

// Programmatic alert (fires once when condition is true)
if ta.crossover(i_alert_src, alert_ma) and barstate.isconfirmed
    alert("LONG signal on " + syminfo.tickerid + " @ " + str.tostring(close, "#.####"), alert.freq_once_per_bar_close)

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 14: Array Usage ══════════════════════════════════════════════════
// Source: get_function("array.push"), get_function("array.pop"),
//         get_function("array.get"),  get_function("array.size")
// Syntax:
//   array.push(id, value) → void        (append to end)
//   array.pop(id)         → series <T>  (remove + return last)
//   array.get(id, index)  → series <T>  (safe: check size first)
//   array.size(id)        → series int
// Validated: pine-facade ✅

i_arr_max = input.int(50, "Array Max Size", minval = 5, maxval = 500)

// Declare with var so array persists across bars
var array<float> close_arr = array.new<float>()

// Push new close each bar
array.push(close_arr, close)

// Bound size — remove oldest element when over limit
if array.size(close_arr) > i_arr_max
    array.shift(close_arr)  // removes first (oldest) element

// Safe read: always bounds-check before array.get()
arr_last_val = array.size(close_arr) > 0 ? array.get(close_arr, array.size(close_arr) - 1) : na
arr_first_val = array.size(close_arr) > 0 ? array.get(close_arr, 0) : na

// Array stats
arr_avg = array.size(close_arr) > 0 ? array.avg(close_arr) : na
arr_max_val = array.size(close_arr) > 0 ? array.max(close_arr) : na
arr_min_val = array.size(close_arr) > 0 ? array.min(close_arr) : na

// ════════════════════════════════════════════════════════════════════════════

