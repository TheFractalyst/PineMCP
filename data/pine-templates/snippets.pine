// ── SNIPPET 19: Pine Type Definition (type keyword) ═══════════════════════════
// Source: get_keyword("type"), get_function("@type")
// Syntax: type <UDT_name> \n  <field_type> <field_name> [= <default>]
// UDT = User-Defined Type. Fields can be any Pine type.
// Validated: pine-facade ✅

// Define a custom signal type
type Signal
    int     bar       = na
    float   price     = na
    string  direction = ""
    bool    active    = false

// Instantiate
var Signal last_signal = Signal.new()

// Update on condition
sn19_cond = ta.crossover(ta.ema(close, 9), ta.ema(close, 21))
if sn19_cond
    last_signal := Signal.new(
         bar       = bar_index,
         price     = close,
         direction = "long",
         active    = true
         )

// Access fields
// last_signal.price → float
// last_signal.direction → string
// last_signal.active → bool

// ════════════════════════════════════════════════════════════════════════════

// ── SNIPPET 20: Method Definition on Custom Type ═════════════════════════════
// Source: get_keyword("method"), MCP example: method maintainArray(...)
// Syntax: method <name>(<UDT> id, ...) => <body>
//   - first parameter must be the UDT type
//   - called with dot notation: myObj.methodName(args)
// Validated: pine-facade ✅

// Rolling window UDT with a bound method
type RollingWindow
    array<float> data    = na
    int          maxSize = 20

// Constructor helper
makeWindow(int sz) =>
    RollingWindow.new(data = array.new<float>(), maxSize = sz)

// Method: push value, maintain bounded size
method push(RollingWindow self, float value) =>
    array.push(self.data, value)
    if array.size(self.data) > self.maxSize
        array.shift(self.data)

// Method: get average of window
method avg(RollingWindow self) =>
    array.size(self.data) > 0 ? array.avg(self.data) : na

// Method: get latest value
method last(RollingWindow self) =>
    sz = array.size(self.data)
    sz > 0 ? array.get(self.data, sz - 1) : na

// Usage
var RollingWindow win = makeWindow(30)
win.push(close)
win_avg  = win.avg()
win_last = win.last()

