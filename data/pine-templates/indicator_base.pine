//@version=6
// ══════════════════════════════════════════════════════════════════════════════
// Base Indicator Template — PineScript v6
// Generated via: generate_indicator("Base Template", "starting point for all indicators", overlay=false)
// Validated: pine-facade ✅ 0 errors
// MCP source: pinescript-v6 MCP server (1,647 entries)
// ══════════════════════════════════════════════════════════════════════════════

indicator(
     title       = "Indicator Title",
     shorttitle  = "IND",
     overlay     = false,
     max_labels_count = 500,
     max_lines_count  = 500,
     max_boxes_count  = 500
     )

// ── INPUTS ────────────────────────────────────────────────────────────────────

// Source input
i_src = input.source(close, title = "Source")

// Integer length input
i_len = input.int(14, title = "Length", minval = 1, maxval = 500, step = 1)

// Float multiplier input
i_mult = input.float(2.0, title = "Multiplier", minval = 0.1, maxval = 10.0, step = 0.1)

// Boolean toggle
i_show_ma = input.bool(true, title = "Show MA")

// Color input
i_col_up   = input.color(color.new(color.green, 0), title = "Up Color")
i_col_down = input.color(color.new(color.red,   0), title = "Down Color")

// Timeframe input (for HTF requests)
// i_tf = input.timeframe("D", title = "Timeframe")

// ── CALCULATIONS ──────────────────────────────────────────────────────────────
// Replace this section with your indicator logic.
// Rules:
//   - Use full namespace: ta.ema() not ema()
//   - Guard na: use na(x) not x == na
//   - Persist state with: var float myVar = na

// Example: EMA
ema_val = ta.ema(i_src, i_len)

// Example: RSI
rsi_val = ta.rsi(i_src, i_len)

// Example: ATR (no source arg — uses high/low/close internally)
atr_val = ta.atr(i_len)

// Example: Bollinger Bands
[bb_basis, bb_upper, bb_lower] = ta.bb(i_src, i_len, i_mult)

// ── PLOT ──────────────────────────────────────────────────────────────────────

plot(i_show_ma ? ema_val : na, title = "EMA", color = i_col_up, linewidth = 2)

// Dynamic color based on condition
rsi_col = rsi_val >= 70 ? i_col_down : rsi_val <= 30 ? i_col_up : color.gray
plot(rsi_val, title = "RSI", color = rsi_col)

// Reference levels
hline(70, "Overbought", color = color.new(color.red,   60), linestyle = hline.style_dashed)
hline(50, "Midline",    color = color.new(color.gray,  60), linestyle = hline.style_dotted)
hline(30, "Oversold",   color = color.new(color.green, 60), linestyle = hline.style_dashed)

// ── LABELS / DRAWINGS (bounded — always delete old objects) ──────────────────

// Example: label at bar high on a condition (use var + delete pattern)
var label lbl_last = na
if barstate.islast
    label.delete(lbl_last)
    lbl_last := label.new(
         point      = chart.point.now(high),
         text       = "RSI: " + str.tostring(rsi_val, "#.##"),
         style      = label.style_label_down,
         color      = color.new(color.blue, 80),
         textcolor  = color.white,
         size       = size.small
         )

// ── ALERTS ────────────────────────────────────────────────────────────────────

alertcondition(
     ta.crossover(rsi_val, 30),
     title   = "RSI Oversold Cross Up",
     message = "RSI crossed above 30: " + str.tostring(rsi_val, "#.##") + " on " + syminfo.tickerid
     )

alertcondition(
     ta.crossunder(rsi_val, 70),
     title   = "RSI Overbought Cross Down",
     message = "RSI crossed below 70: " + str.tostring(rsi_val, "#.##") + " on " + syminfo.tickerid
     )
